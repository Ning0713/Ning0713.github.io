---
import { getCollection } from 'astro:content';
import EmptyState from '../../components/EmptyState.astro';
import PageHeader from '../../components/PageHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { dedupeEntriesBySlug, formatDate, sortByDateDesc } from '../../lib/content';

const projects = dedupeEntriesBySlug(await getCollection('projects', ({ data }) => !data.draft)).sort(sortByDateDesc);
---

<BaseLayout title={`Projects | ${SITE_TITLE}`} description="Engineering projects, experiments, and long-running builds.">
  <PageHeader
    eyebrow="Projects"
    title="Engineering logs and playable experiments."
    description="A restrained card list for project showcases such as Game Jam development, desktop tooling, research prototypes, or internal engineering case studies."
  />

  {projects.length > 0 ? (
    <div class="grid gap-5 lg:grid-cols-2">
      {projects.map((project) => (
        <article class="surface-card rounded-[2rem] border border-line/80 p-6 shadow-card transition duration-300 hover:-translate-y-1 hover:border-accent/50">
          <div class="flex flex-wrap items-center gap-3 text-sm text-muted">
            <time datetime={project.data.date.toISOString()}>{formatDate(project.data.date)}</time>
            <span aria-hidden="true">/</span>
            <span class="capitalize">{project.data.status}</span>
          </div>
          <h2 class="mt-4 text-2xl font-bold tracking-tight text-ink">
            <a href={`/projects/${project.slug}`} class="hover:text-accent">{project.data.title}</a>
          </h2>
          <p class="mt-3 leading-7 text-muted">{project.data.description}</p>

          {project.data.tags.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-2">
              {project.data.tags.map((tag) => (
                <li class="rounded-full border border-line/70 px-3 py-1 text-xs text-muted">
                  #{tag}
                </li>
              ))}
            </ul>
          )}

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={`/projects/${project.slug}`}
              class="rounded-full border border-line/80 px-4 py-2 text-sm text-muted hover:border-accent/50 hover:text-ink"
            >
              Read case study
            </a>
            {project.data.repo && (
              <a
                href={project.data.repo}
                class="rounded-full border border-line/80 px-4 py-2 text-sm text-muted hover:border-accent/50 hover:text-ink"
              >
                Repository
              </a>
            )}
            {project.data.demo && (
              <a
                href={project.data.demo}
                class="rounded-full border border-line/80 px-4 py-2 text-sm text-muted hover:border-accent/50 hover:text-ink"
              >
                Live Demo
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  ) : (
    <EmptyState
      title="Projects collection is wired up"
      description="Drop content files into src/content/projects and they will automatically appear in this card layout."
    />
  )}
</BaseLayout>
