---
import PageHeader from '../components/PageHeader.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import { ABOUT_INTRO_PARAGRAPHS } from '../data/profile';

const sections = [
  { slug: 'introduction', text: 'Introduction', depth: 2 },
  { slug: 'focus', text: 'Current Focus', depth: 2 },
  { slug: 'tools', text: 'Tool Stack', depth: 2 },
  { slug: 'site-notes', text: 'Site Notes', depth: 2 },
  { slug: 'license', text: 'License', depth: 2 },
];

const focusAreas = [
  {
    title: 'Security and reverse engineering',
    description:
      'Long-form notes around mobile systems, Android reverse engineering, and the way security ideas become concrete through repeated practice.',
  },
  {
    title: 'Deep learning and technical reading',
    description:
      'Learning in public through reading logs, concept breakdowns, and careful attempts to turn difficult material into something durable and searchable.',
  },
  {
    title: 'Frontend engineering and tooling',
    description:
      'Using Astro and modern frontend workflows to build a site that can hold research notes, project write-ups, and personal essays in one coherent system.',
  },
];

const tools = [
  {
    name: 'VS Code',
    description: 'Primary editor for web work, note-taking, and Markdown-heavy authoring.',
  },
  {
    name: 'Cursor',
    description: 'AI-assisted coding environment for refactors, prototyping, and content polishing.',
  },
  {
    name: 'Unity',
    description: 'Game jam and interactive prototype development, especially for experimental ideas.',
  },
  {
    name: 'Blender',
    description: '3D asset blocking, quick rendering, and pipeline support for game-oriented work.',
  },
];

const siteNotes = [
  { label: 'Framework', value: 'Astro + Tailwind CSS + MDX' },
  { label: 'Architecture', value: 'Collection-driven content, nested slug routes, and reusable layouts for long-form writing.' },
  { label: 'Primary Sections', value: 'Blog, Projects, Academic, Links, and About.' },
  { label: 'Direction', value: 'A scholar-geek personal site with clear typography, quiet structure, and durable notes.' },
];
---

<BaseLayout title={`About | ${SITE_TITLE}`} description="About this site, the workflow behind it, and the publishing principles that guide it.">
  <div class="mx-auto w-full max-w-6xl">
    <div class="lg:grid lg:grid-cols-[minmax(0,44rem)_16rem] lg:gap-12">
      <div>
        <PageHeader
          eyebrow="About"
          title="Building a small, durable place on the web."
          description="This page collects the personal introduction, working focus, tool choices, and publishing notes behind the site."
        />

        <div class="mb-10 lg:hidden">
          <TableOfContents items={sections} />
        </div>

        <div class="space-y-12">
          <section id="introduction" data-anchor-section class="border-t border-line/80 pt-8">
            <div class="max-w-3xl">
              <p class="eyebrow-label">01</p>
              <h2 class="mt-3 font-serif text-3xl font-bold text-ink">Introduction</h2>
            </div>
            <article class="surface-card mt-6 rounded-[2rem] border border-line/80 p-8 shadow-card">
              <div class="space-y-4 leading-8 text-muted">
                {ABOUT_INTRO_PARAGRAPHS.map((paragraph) => (
                  <p class="profile-copy">{paragraph}</p>
                ))}
              </div>
            </article>
          </section>

          <section id="focus" data-anchor-section class="border-t border-line/80 pt-8">
            <div class="max-w-3xl">
              <p class="eyebrow-label">02</p>
              <h2 class="mt-3 font-serif text-3xl font-bold text-ink">Current Focus</h2>
              <p class="mt-3 leading-8 text-muted">
                The current direction of the site is to let research notes, engineering practice, and personal writing live side by side without feeling like separate products.
              </p>
            </div>

            <div class="mt-6 grid gap-5 md:grid-cols-3">
              {focusAreas.map((area) => (
                <article class="surface-card rounded-[1.75rem] border border-line/80 p-6 shadow-card">
                  <h3 class="text-lg font-bold text-ink">{area.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-muted">{area.description}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="tools" data-anchor-section class="border-t border-line/80 pt-8">
            <div class="max-w-3xl">
              <p class="eyebrow-label">03</p>
              <h2 class="mt-3 font-serif text-3xl font-bold text-ink">Tool Stack</h2>
            </div>

            <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
              {tools.map((tool) => (
                <article class="surface-card rounded-[1.75rem] border border-line/80 p-6 shadow-card">
                  <p class="eyebrow-label">Workflow</p>
                  <h3 class="mt-3 text-xl font-bold text-ink">{tool.name}</h3>
                  <p class="mt-3 text-sm leading-7 text-muted">{tool.description}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="site-notes" data-anchor-section class="border-t border-line/80 pt-8">
            <div class="max-w-3xl">
              <p class="eyebrow-label">04</p>
              <h2 class="mt-3 font-serif text-3xl font-bold text-ink">Site Notes</h2>
            </div>

            <article class="surface-card mt-6 rounded-[2rem] border border-line/80 p-8 shadow-card">
              <dl class="space-y-5 text-sm leading-7 text-muted">
                {siteNotes.map((item) => (
                  <div class="grid gap-1 sm:grid-cols-[10rem_minmax(0,1fr)] sm:gap-4">
                    <dt class="font-semibold text-ink">{item.label}</dt>
                    <dd>{item.value}</dd>
                  </div>
                ))}
              </dl>
            </article>
          </section>

          <section id="license" data-anchor-section class="border-t border-line/80 pt-8">
            <div class="max-w-3xl">
              <p class="eyebrow-label">05</p>
              <h2 class="mt-3 font-serif text-3xl font-bold text-ink">License</h2>
            </div>

            <article class="surface-card mt-6 rounded-[2rem] border border-line/80 p-8 shadow-card">
              <p class="eyebrow-label">Copyright</p>
              <h3 class="mt-3 font-serif text-3xl font-bold text-ink">CC BY-NC-SA 4.0</h3>
              <p class="mt-4 max-w-3xl leading-8 text-muted">
                Unless otherwise noted, original writing and media on this site are shared under the
                Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International License.
                Please credit the source, avoid commercial reuse, and preserve the same license when
                adapting the material.
              </p>
              <a
                href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
                class="mt-5 inline-flex rounded-full border border-line/80 px-4 py-2 text-sm text-muted hover:border-accent/50 hover:text-ink"
              >
                Read the license
              </a>
            </article>
          </section>
        </div>
      </div>

      <aside class="hidden lg:block lg:sticky lg:top-32 lg:self-start">
        <TableOfContents items={sections} />
      </aside>
    </div>
  </div>
</BaseLayout>
