---
import { getCollection } from 'astro:content';
import BlogExplorer from '../../components/BlogExplorer.astro';
import { getBlogCollectionOverview, buildBlogPaginationLinks, getBlogCollectionPageHref, getBlogTagOverview, paginateBlogPosts, sortBlogPosts } from '../../lib/blog';

export async function getStaticPaths() {
  const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
  const collections = getBlogCollectionOverview(allPosts);

  return collections.map((collection) => ({
    params: { collection: encodeURIComponent(collection.label) },
    props: { collectionName: collection.label },
  }));
}

const { collectionName } = Astro.props;
const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const posts = allPosts.filter((post) => post.data.collection === collectionName);
const pagination = paginateBlogPosts(posts, 1);
const paginationLinks = buildBlogPaginationLinks(pagination.totalPages, pagination.page, (page) =>
  getBlogCollectionPageHref(collectionName, page),
);
---

<BlogExplorer
  title={collectionName}
  description={`${collectionName} 分类下的文章归档。`}
  eyebrow="分类"
  pagination={pagination}
  paginationLinks={paginationLinks}
  collections={getBlogCollectionOverview(allPosts)}
  tags={getBlogTagOverview(allPosts)}
  currentCollection={collectionName}
/>
