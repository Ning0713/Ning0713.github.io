---
import { getCollection } from 'astro:content';
import BlogExplorer from '../../components/BlogExplorer.astro';
import {
  buildBlogPaginationLinks,
  getBlogCollectionOverview,
  getBlogCollectionPageHref,
  getBlogTagOverview,
  getPostsForBlogCollection,
  paginateBlogPosts,
  sortBlogPosts,
} from '../../lib/blog';

export async function getStaticPaths() {
  const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
  const postCollections = await getCollection('postCollections', ({ data }) => !data.draft);
  const collections = getBlogCollectionOverview(allPosts, postCollections);

  return collections.flatMap((collection) => {
    const pathSegments = [...new Set([collection.slug, collection.label])];

    return pathSegments.map((pathSegment) => ({
      params: { collection: pathSegment },
      props: { collectionInfo: collection },
    }));
  });
}

const { collectionInfo } = Astro.props;
const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const postCollections = await getCollection('postCollections', ({ data }) => !data.draft);
const collections = getBlogCollectionOverview(allPosts, postCollections);
const posts = getPostsForBlogCollection(collectionInfo, allPosts);
const pagination = paginateBlogPosts(posts, 1);
const paginationLinks = buildBlogPaginationLinks(pagination.totalPages, pagination.page, (page) =>
  getBlogCollectionPageHref(collectionInfo.slug, page),
);
---

<BlogExplorer
  title={collectionInfo.label}
  description={collectionInfo.description ?? `${collectionInfo.label} 分类下的文章归档。`}
  pagination={pagination}
  paginationLinks={paginationLinks}
  collections={collections}
  tags={getBlogTagOverview(allPosts)}
  currentCollection={collectionInfo.label}
  collectionHero={{
    title: collectionInfo.label,
    description: collectionInfo.description,
    cover: collectionInfo.cover,
  }}
/>
