---
import { getCollection } from 'astro:content';
import BlogExplorer from '../../../../../components/BlogExplorer.astro';
import {
  buildBlogPaginationLinks,
  getBlogCollectionOverview,
  getBlogTagOverview,
  getBlogTagPageHref,
  paginateBlogPosts,
  sortBlogPosts,
} from '../../../../../lib/blog';

export async function getStaticPaths() {
  const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
  const tags = getBlogTagOverview(allPosts);

  return tags.flatMap((tag) => {
    const taggedPosts = allPosts.filter((post) => post.data.tags.some((entry) => entry === tag.tag));
    const { totalPages } = paginateBlogPosts(taggedPosts, 1);

    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
      params: {
        tag: tag.tag,
        page: String(index + 2),
      },
      props: { tag: tag.tag },
    }));
  });
}

const { tag } = Astro.props;
const page = Number(Astro.params.page ?? '1');
const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const postCollections = await getCollection('postCollections', ({ data }) => !data.draft);
const posts = allPosts.filter((post) => post.data.tags.some((entry) => entry === tag));
const pagination = paginateBlogPosts(posts, page);
const paginationLinks = buildBlogPaginationLinks(pagination.totalPages, pagination.page, (targetPage) =>
  getBlogTagPageHref(tag, targetPage),
);
---

<BlogExplorer
  title={`#${tag}`}
  description={`Posts tagged with ${tag}. Use collections and tags on the right to continue exploring the blog.`}
  pagination={pagination}
  paginationLinks={paginationLinks}
  collections={getBlogCollectionOverview(allPosts, postCollections)}
  tags={getBlogTagOverview(allPosts)}
  currentTag={tag}
/>
