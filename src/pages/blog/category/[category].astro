---
import { getCollection } from 'astro:content';
import BlogExplorer from '../../../components/BlogExplorer.astro';
import { BLOG_CATEGORY_ITEMS, BLOG_CATEGORY_META } from '../../../consts';
import {
  buildBlogPaginationLinks,
  getBlogCollectionOverview,
  getBlogCategoryPageHref,
  getBlogTagOverview,
  paginateBlogPosts,
  sortBlogPosts,
} from '../../../lib/blog';

type BlogCategory = keyof typeof BLOG_CATEGORY_META;

export async function getStaticPaths() {
  return BLOG_CATEGORY_ITEMS.map((item) => ({
    params: { category: item.slug },
  }));
}

const category = Astro.params.category as BlogCategory;
const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const posts = allPosts.filter((post) => post.data.category === category);
const pagination = paginateBlogPosts(posts, 1);
const paginationLinks = buildBlogPaginationLinks(pagination.totalPages, pagination.page, (page) =>
  getBlogCategoryPageHref(category, page),
);
---

<BlogExplorer
  title={BLOG_CATEGORY_META[category].label}
  description={BLOG_CATEGORY_META[category].description}
  pagination={pagination}
  paginationLinks={paginationLinks}
  collections={getBlogCollectionOverview(allPosts)}
  tags={getBlogTagOverview(allPosts)}
  currentSectionLabel={BLOG_CATEGORY_META[category].label}
/>
