---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import { getBlogCollectionOverview, sortBlogPosts } from '../lib/blog';

const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const postCollections = await getCollection('postCollections', ({ data }) => !data.draft);
const collections = getBlogCollectionOverview(allPosts, postCollections);
---

<BaseLayout title={`分类 | ${SITE_TITLE}`} description="按主题整理的博客分类入口。">
  <header class="mb-8 border-b border-line/80 pb-6">
    <p class="text-sm tracking-[0.08em] text-muted">分类总览</p>
    <h1 class="collection-display-title mt-4 text-4xl leading-none text-ink sm:text-5xl">分类</h1>
    <p class="mt-4 max-w-3xl text-sm leading-7 text-muted sm:text-base">
      按主题整理博客内容，方便快速浏览不同方向的文章。
    </p>
  </header>

  <section class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {collections.map((collection) => (
      <a
        href={collection.href}
        class:list={[
          'collection-preview-card group relative flex flex-col overflow-hidden rounded-[1.05rem] border border-line/80 bg-card/72 shadow-card transition duration-300 hover:-translate-y-0.5 hover:border-accent/45',
          collection.cover && 'collection-pill-card-with-cover',
        ]}
      >
        {collection.cover ? (
          <div class="collection-preview-media">
            <img
              src={collection.cover}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              class="collection-preview-image"
            />
            <div class="collection-preview-overlay">
              <h2 class="collection-card-title line-clamp-2 text-2xl leading-tight text-white">{collection.label}</h2>
              <p class="collection-preview-description mt-2 line-clamp-2 text-sm leading-6">
                {collection.description ?? `${collection.count} posts in this collection.`}
              </p>
            </div>
          </div>
        ) : (
          <div class="collection-preview-empty">
            <div class="flex items-center justify-between">
              <span class="collection-preview-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="h-8 w-8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 8-9-5-9 5 9 5 9-5Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="m3 8 9 5 9-5M3 12l9 5 9-5M3 16l9 5 9-5" />
                </svg>
              </span>
              <span class="rounded-full border border-line/75 px-3 py-1 text-xs text-muted">{collection.count} posts</span>
            </div>
            <div>
              <h2 class="collection-card-title line-clamp-2 text-2xl leading-tight text-ink">{collection.label}</h2>
              <p class="mt-2 line-clamp-3 text-sm leading-6 text-muted">
                {collection.description ?? `${collection.count} posts in this collection.`}
              </p>
            </div>
          </div>
        )}

        <div class="collection-preview-footer">
          <span>View Collection</span>
          <span class="collection-card-arrow inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full transition group-hover:translate-x-1 group-hover:text-accent">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                clip-rule="evenodd"
              />
            </svg>
          </span>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .collection-display-title,
  .collection-card-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-weight: 500;
    letter-spacing: -0.05em;
  }

  .collection-preview-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .collection-preview-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.78);
    transition: transform 360ms ease, filter 240ms ease;
  }

  .collection-preview-card:hover .collection-preview-image {
    transform: scale(1.035);
    filter: brightness(0.86);
  }

  .collection-preview-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(to top, rgb(0 0 0 / 0.78), rgb(0 0 0 / 0.24) 58%, transparent);
  }

  .collection-preview-description {
    color: rgb(255 255 255 / 0.86);
  }

  .collection-preview-empty {
    display: flex;
    min-height: 15rem;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem;
  }

  .collection-preview-icon {
    display: inline-flex;
    width: 3.25rem;
    height: 3.25rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(var(--color-line) / 0.75);
    border-radius: 0.9rem;
    color: rgb(var(--color-accent));
    background: rgb(var(--color-line) / 0.25);
  }

  .collection-preview-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgb(var(--color-line) / 0.75);
    padding: 1rem 1.25rem;
    font-size: 1rem;
    color: rgb(var(--color-ink));
    transition: color 180ms ease;
  }

  .collection-preview-card:hover .collection-preview-footer {
    color: rgb(var(--color-accent));
  }
</style>
