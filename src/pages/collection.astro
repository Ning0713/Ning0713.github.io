---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import { getBlogCollectionOverview, sortBlogPosts } from '../lib/blog';

const allPosts = sortBlogPosts(await getCollection('blog', ({ data }) => !data.draft));
const collections = getBlogCollectionOverview(allPosts);
---

<BaseLayout title={`分类 | ${SITE_TITLE}`} description="按主题整理的博客分类入口。">
  <header class="mb-12 border-b border-line/80 pb-8">
    <p class="text-sm tracking-[0.08em] text-muted">分类总览</p>
    <h1 class="collection-display-title mt-5 text-5xl leading-none text-ink sm:text-6xl">分类</h1>
    <p class="mt-5 max-w-3xl text-base leading-8 text-muted sm:text-lg">
      按主题整理博客内容，方便快速浏览不同方向的文章。
    </p>
  </header>

  <section class="grid gap-5 md:grid-cols-2">
    {collections.map((collection) => (
      <a
        href={collection.href}
        class="surface-card group rounded-[2rem] border border-line/80 p-6 shadow-card transition duration-300 hover:-translate-y-1 hover:border-accent/50"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm text-muted">分类</p>
            <h2 class="collection-card-title mt-3 text-3xl leading-none text-ink">{collection.label}</h2>
          </div>
          <span class="rounded-full border border-line/70 px-3 py-1 text-sm text-muted">
            {collection.count} posts
          </span>
        </div>

        <div class="mt-7 inline-flex items-center gap-2 text-sm text-ink">
          <span>查看分类</span>
          <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .collection-display-title,
  .collection-card-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-weight: 500;
    letter-spacing: -0.05em;
  }
</style>
