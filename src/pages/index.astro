---
import { getCollection } from 'astro:content';
import GitHubContributionSection from '../components/GitHubContributionSection.astro';
import { PROFILE_HOME_BIO, PROFILE_HOME_ROLE } from '../data/profile';
import { getGitHubContributionCalendar } from '../lib/github';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { dedupeEntriesBySlug, formatDate, sortByDateDesc } from '../lib/content';
import { countCollectionWords } from '../lib/stats';
import avatarImage from '../../res/千咲头像.jpg';
import zhihuIcon from '../../res/知乎.svg';

const posts = dedupeEntriesBySlug(await getCollection('blog', ({ data }) => !data.draft)).sort(sortByDateDesc);
const projects = dedupeEntriesBySlug(await getCollection('projects', ({ data }) => !data.draft)).sort(sortByDateDesc);
const academic = dedupeEntriesBySlug(await getCollection('academic', ({ data }) => !data.draft)).sort(sortByDateDesc);

const launchDate = new Date('2026-04-01');
const daysOnline = Math.max(1, Math.ceil((Date.now() - launchDate.getTime()) / 86_400_000));
const totalWords = countCollectionWords([...posts, ...projects, ...academic]);
const githubContributions = await getGitHubContributionCalendar();

const latestUpdated = [posts[0]?.data.date, projects[0]?.data.date, academic[0]?.data.date]
  .filter((value): value is Date => value instanceof Date)
  .sort((left, right) => right.valueOf() - left.valueOf())[0];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="mx-auto w-full max-w-5xl space-y-14">
    <section class="surface-card rounded-[2rem] border border-line/80 p-5 shadow-card sm:p-6 lg:ml-[12.5rem]">
      <div class="grid gap-6 lg:grid-cols-[9rem_minmax(0,1fr)] lg:items-center">
        <div class="overflow-hidden rounded-2xl border border-line/80 bg-paper/60 p-1 shadow-card">
          <img
            src={avatarImage.src}
            alt={`${SITE_TITLE} avatar`}
            class="aspect-square w-full rounded-xl object-cover"
            loading="eager"
          />
        </div>
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-ink sm:text-3xl">{SITE_TITLE}</h1>
          <div class="mt-5 flex flex-wrap gap-2.5">
            <span class="inline-flex items-center gap-2 rounded-2xl border border-line/80 px-3.5 py-1.5 text-xs text-muted sm:text-sm">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                class="h-4 w-4"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s6-5.33 6-11a6 6 0 1 0-12 0c0 5.67 6 11 6 11Z" />
                <circle cx="12" cy="10" r="2.5" />
              </svg>
              <span>China, Nanjing</span>
            </span>
            <a
              href="https://github.com/Ning0713"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 rounded-2xl border border-line/80 px-3.5 py-1.5 text-xs text-muted hover:border-accent/50 hover:text-ink sm:text-sm"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-4 w-4"
                aria-hidden="true"
              >
                <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.41-4.04-1.41-.55-1.37-1.33-1.73-1.33-1.73-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.22 1.84 1.22 1.08 1.82 2.82 1.29 3.51.98.11-.76.42-1.29.77-1.59-2.67-.3-5.48-1.31-5.48-5.86 0-1.3.47-2.36 1.23-3.19-.12-.3-.53-1.52.12-3.18 0 0 1.01-.32 3.3 1.22a11.6 11.6 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.66.25 2.88.12 3.18.77.83 1.23 1.89 1.23 3.19 0 4.56-2.81 5.55-5.49 5.85.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z" />
              </svg>
              <span>Github</span>
            </a>
            <a
              href="https://www.zhihu.com/people/Ning0713"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 rounded-2xl border border-line/80 px-3.5 py-1.5 text-xs text-muted hover:border-accent/50 hover:text-ink sm:text-sm"
            >
              <img src={zhihuIcon.src} alt="" aria-hidden="true" class="h-4 w-4" />
              <span>Zhihu</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[11rem_minmax(0,1fr)]">
      <h2 class="pt-2 text-2xl font-bold text-black dark:text-ink">About</h2>
      <div class="surface-card rounded-[2rem] border border-line/80 p-7 shadow-card">
        <p class="profile-copy text-base text-black dark:text-ink">{PROFILE_HOME_ROLE}</p>
        <p class="profile-copy mt-7 text-sm leading-8 text-black dark:text-ink sm:text-base">
          {PROFILE_HOME_BIO}
        </p>
        <div class="mt-7 flex justify-end">
          <a
            href="/about"
            class="rounded-2xl border border-line/80 px-5 py-2.5 text-xs text-muted hover:border-accent/50 hover:text-ink sm:text-sm"
          >
            More about me
          </a>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[11rem_minmax(0,1fr)]">
      <h2 class="pt-2 text-2xl font-bold text-black dark:text-ink">Education</h2>
      <div class="space-y-5">
        <article class="surface-card rounded-[2rem] border border-line/80 p-7 shadow-card">
          <h3 class="text-lg font-bold text-black dark:text-ink sm:text-xl">南京信息工程大学</h3>
          <p class="mt-3 text-sm font-normal text-black dark:text-ink sm:text-base">计算机科学与技术专业，本科</p>
          <p
            class="mt-2 text-xs font-normal italic text-black dark:text-ink sm:text-sm"
            style="font-family: 'Times New Roman', Times, serif;"
          >
            Sep 2023 - Present
          </p>
        </article>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[11rem_minmax(0,1fr)]">
      <h2 class="pt-2 text-2xl font-bold text-black dark:text-ink">Statistics</h2>
      <div class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-3">
          <article class="surface-card rounded-[1.75rem] border border-line/80 p-6 shadow-card">
            <p class="text-xs text-black dark:text-ink sm:text-sm">Days Online</p>
            <p class="mt-4 text-2xl font-bold text-black dark:text-ink">{daysOnline}</p>
          </article>
          <article class="surface-card rounded-[1.75rem] border border-line/80 p-6 shadow-card">
            <p class="text-xs text-black dark:text-ink sm:text-sm">Last Updated</p>
            <p class="mt-4 text-base font-bold text-black dark:text-ink sm:text-lg">{latestUpdated ? formatDate(latestUpdated) : 'N/A'}</p>
          </article>
          <article class="surface-card rounded-[1.75rem] border border-line/80 p-6 shadow-card">
            <p class="text-xs text-black dark:text-ink sm:text-sm">Total Words</p>
            <p class="mt-4 text-2xl font-bold text-black dark:text-ink">{totalWords.toLocaleString('en-US')}</p>
          </article>
        </div>

        <article class="surface-card flex items-center justify-between rounded-2xl border border-line/80 px-5 py-3.5 shadow-card">
          <p class="text-sm font-normal text-black dark:text-ink sm:text-base">Total Posts</p>
          <p class="text-lg font-normal text-black dark:text-ink sm:text-xl">{posts.length}</p>
        </article>
      </div>
    </section>

    <GitHubContributionSection data={githubContributions} />
  </section>
</BaseLayout>
