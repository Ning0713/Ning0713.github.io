---
import PageHeader from '../components/PageHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';

const links = [
  {
    name: 'Axi404',
    href: 'https://axi404.top/',
    note: 'Reference for the scholar-geek visual direction and information architecture.',
  },
  {
    name: 'Astro',
    href: 'https://astro.build/',
    note: 'Static-first framework used as the foundation of this website.',
  },
  {
    name: 'Tailwind CSS',
    href: 'https://tailwindcss.com/',
    note: 'Utility-first styling layer for consistent spacing, typography, and theming.',
  },
];
---

<BaseLayout title={`Links | ${SITE_TITLE}`} description="Friends, inspirations, and useful resources.">
  <PageHeader
    eyebrow="Links"
    title="Friends and references."
    description="A quiet page for mutual links, favorite resources, and projects that shaped this website."
  />

  <div class="grid gap-5">
    {links.map((link) => (
      <a
        href={link.href}
        class="surface-card group rounded-3xl border border-line/80 p-6 shadow-card transition duration-300 hover:-translate-y-1 hover:border-accent/50"
      >
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-xl font-bold text-ink group-hover:text-accent">{link.name}</h2>
            <p class="mt-2 leading-7 text-muted">{link.note}</p>
          </div>
          <span class="font-mono text-xs uppercase tracking-[0.24em] text-muted">Visit</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
