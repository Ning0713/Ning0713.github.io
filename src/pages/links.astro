---
import PageHeader from '../components/PageHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';

const links = [
  {
    name: 'Axi404',
    href: 'https://axi404.top/',
    note: 'Reference for the scholar-geek visual direction and information architecture.',
  },
  {
    name: 'Astro',
    href: 'https://astro.build/',
    note: 'Static-first framework used as the foundation of this website.',
  },
  {
    name: 'Tailwind CSS',
    href: 'https://tailwindcss.com/',
    note: 'Utility-first styling layer for consistent spacing, typography, and theming.',
  },
];
---

<BaseLayout title={`Links | ${SITE_TITLE}`} description="Friends, inspirations, and useful resources.">
  <PageHeader
    eyebrow="Links"
    title="Friends and references."
    description="A quiet page for mutual links, favorite resources, and projects that shaped this website."
  />

  <div class="grid gap-3">
    {links.map((link) => (
      <a
        href={link.href}
        class="link-preview-card group flex items-center justify-between gap-5 rounded-[1.4rem] border border-line/80 bg-card/72 px-5 py-4 shadow-card transition duration-300 hover:-translate-y-0.5 hover:border-accent/45"
      >
        <div class="min-w-0">
          <h2 class="link-preview-title text-xl font-medium leading-tight text-ink transition group-hover:text-accent sm:text-2xl">{link.name}</h2>
          <p class="mt-1 text-sm leading-6 text-muted">{link.note}</p>
        </div>
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-ink transition group-hover:translate-x-1 group-hover:text-accent">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .link-preview-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    letter-spacing: -0.03em;
  }
</style>
