---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from './EmptyState.astro';
import { BLOG_CATEGORY_ITEMS, SITE_TITLE } from '../consts';
import type { BlogCollectionOverview, BlogPaginationResult, BlogTagOverview } from '../lib/blog';
import { getBlogCategoryPageHref, getBlogCollectionPageHref, getBlogTagPageHref } from '../lib/blog';
import { formatDate } from '../lib/content';
import { countReadableWords } from '../lib/stats';

interface Props {
  title: string;
  description: string;
  pagination: BlogPaginationResult;
  collections: BlogCollectionOverview[];
  tags: BlogTagOverview[];
  paginationLinks: { page: number; href: string; isCurrent: boolean }[];
  currentSectionLabel?: string;
  currentCollection?: string;
  currentTag?: string;
  collectionHero?: {
    title: string;
    description?: string;
    cover?: string;
  };
}

const {
  title,
  description,
  pagination,
  collections,
  tags,
  paginationLinks,
  currentSectionLabel,
  currentCollection,
  currentTag,
  collectionHero,
} = Astro.props;

const pageTitle = `${title} | ${SITE_TITLE}`;
const hasPosts = pagination.posts.length > 0;
const previousPageHref = pagination.page > 1 ? paginationLinks[pagination.page - 2]?.href : null;
const nextPageHref = pagination.page < pagination.totalPages ? paginationLinks[pagination.page]?.href : null;
const currentCollectionIndex = currentCollection ? collections.findIndex((item) => item.label === currentCollection) : -1;
const previousCollection = currentCollectionIndex > 0 ? collections[currentCollectionIndex - 1] : null;
const nextCollection =
  currentCollectionIndex >= 0 && currentCollectionIndex < collections.length - 1
    ? collections[currentCollectionIndex + 1]
    : null;
const currentCategoryIndex =
  currentSectionLabel && !currentCollection && !currentTag
    ? BLOG_CATEGORY_ITEMS.findIndex((item) => item.label === currentSectionLabel)
    : -1;
const previousCategory = currentCategoryIndex > 0 ? BLOG_CATEGORY_ITEMS[currentCategoryIndex - 1] : null;
const nextCategory =
  currentCategoryIndex >= 0 && currentCategoryIndex < BLOG_CATEGORY_ITEMS.length - 1
    ? BLOG_CATEGORY_ITEMS[currentCategoryIndex + 1]
    : null;
const previousNavItem = previousCollection
  ? { href: previousCollection.href, label: previousCollection.label }
  : previousCategory
    ? { href: getBlogCategoryPageHref(previousCategory.slug), label: previousCategory.label }
    : null;
const nextNavItem = nextCollection
  ? { href: nextCollection.href, label: nextCollection.label }
  : nextCategory
    ? { href: getBlogCategoryPageHref(nextCategory.slug), label: nextCategory.label }
    : null;

const getReadingMinutes = (post: CollectionEntry<'blog'>) => {
  const words = countReadableWords([post.data.title, post.data.description, post.body ?? ''].join(' '));
  return Math.max(1, Math.ceil(words / 420));
};

const displayPosts = pagination.posts.map((post) => {
  const cover = post.data.cover?.trim() ?? '';
  return {
    post,
    cover,
    hasCover: cover.length > 0,
  };
});

const getCollectionHref = (collectionName: string) =>
  collections.find((collection) => collection.label === collectionName || collection.slug === collectionName)?.href ??
  getBlogCollectionPageHref(collectionName);
---

<BaseLayout title={pageTitle} description={description}>
  {collectionHero && (
    <section class:list={['collection-detail-hero -mt-1 mb-7', collectionHero.cover && 'collection-detail-hero-with-cover']}>
      {collectionHero.cover ? (
        <img
          src={collectionHero.cover}
          alt=""
          aria-hidden="true"
          loading="eager"
          decoding="async"
          class="collection-detail-hero-image"
        />
      ) : (
        <div class="collection-detail-hero-empty" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="h-12 w-12">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 8-9-5-9 5 9 5 9-5Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="m3 8 9 5 9-5M3 12l9 5 9-5M3 16l9 5 9-5" />
          </svg>
        </div>
      )}

      <div class="collection-detail-hero-overlay">
        <h1 class="collection-detail-hero-title">{collectionHero.title}</h1>
        {collectionHero.description && (
          <p class="collection-detail-hero-description">{collectionHero.description}</p>
        )}
      </div>
    </section>
  )}

  {!collectionHero && (
    <header class="blog-index-header -mt-2 mb-8 border-b border-line/80 pb-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="blog-display-title text-3xl leading-none text-ink sm:text-4xl">{title}</h1>

          {(currentCollection || currentCategoryIndex >= 0) && (
            <div class="flex items-center gap-1.5 pt-0.5">
              {previousNavItem ? (
                <a
                  href={previousNavItem.href}
                  aria-label={`Go to ${previousNavItem.label}`}
                  class="blog-nav-arrow"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M12.78 4.22a.75.75 0 0 1 0 1.06L8.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06l-5.25-5.25a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              ) : (
                <span class="blog-nav-arrow blog-nav-arrow-disabled" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M12.78 4.22a.75.75 0 0 1 0 1.06L8.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06l-5.25-5.25a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              )}

              {nextNavItem ? (
                <a
                  href={nextNavItem.href}
                  aria-label={`Go to ${nextNavItem.label}`}
                  class="blog-nav-arrow"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              ) : (
                <span class="blog-nav-arrow blog-nav-arrow-disabled" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              )}
            </div>
          )}
        </div>

        <p class="text-xs leading-5 text-muted sm:text-right">
          Page {pagination.page} of {pagination.totalPages} · Showing {pagination.startIndex}-{pagination.endIndex} of {pagination.totalPosts}
        </p>
      </div>
    </header>
  )}

  <div class:list={['grid gap-10 lg:items-start', collectionHero ? 'collection-detail-posts' : 'lg:grid-cols-[minmax(0,48rem)_minmax(18rem,1fr)]']}>
    <div class="space-y-7">
      {hasPosts ? (
        <ul class="blog-post-list space-y-3.5">
          {displayPosts.map(({ post, cover, hasCover }) => (
            <li>
              <article
                class:list={[
                  'blog-post-card group/card relative min-h-[13.5rem] overflow-hidden rounded-[1.45rem] border border-line/80 bg-card/72 p-4 shadow-card transition duration-300 hover:-translate-y-0.5 hover:border-accent/45 sm:p-5',
                  hasCover && 'blog-post-card-with-cover',
                ]}
              >
                {hasCover && (
                  <img
                    src={cover}
                    alt=""
                    aria-hidden="true"
                    loading="lazy"
                    decoding="async"
                    class="blog-cover-image"
                  />
                )}

                <a href={`/blog/${post.slug}`} class="blog-card-stretched-link" aria-label={`Read ${post.data.title}`}>
                  <span class="blog-card-arrow absolute right-4 top-1/2 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full text-ink transition group-hover/card:translate-x-1 group-hover/card:text-accent">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      class="h-5 w-5"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </span>
                </a>

                <div class:list={['blog-card-content pointer-events-none pr-8', hasCover && 'max-w-[72%] max-sm:max-w-none']}>
                  <time class="blog-post-date text-xs leading-6 text-muted" datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>

                  <h2 class="blog-post-title mt-1.5 text-lg font-medium leading-snug text-ink transition group-hover/card:text-accent sm:text-xl">
                    {post.data.title}
                  </h2>
                  <p class="mt-1.5 max-w-reading text-sm leading-6 text-muted">
                    {post.data.description}
                  </p>
                  <div class="mt-2.5 inline-flex items-center gap-2 text-xs italic text-muted">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      class="h-4 w-4"
                      aria-hidden="true"
                    >
                      <circle cx="12" cy="12" r="9" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 2" />
                    </svg>
                    <span>{getReadingMinutes(post)} min read</span>
                  </div>
                </div>

                <div class="blog-card-actions mt-4 flex flex-wrap gap-2">
                  <a
                    href={getCollectionHref(post.data.collection)}
                    class="blog-pill-button"
                  >
                    {post.data.collection}
                  </a>
                  {post.data.tags.map((tag) => (
                    <a
                      href={getBlogTagPageHref(tag)}
                      class:list={[
                        'blog-pill-button',
                        currentTag === tag && 'blog-pill-button-active',
                      ]}
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <EmptyState
          title="No posts yet"
          description="This route is ready. Add matching MD or MDX files under src/content/blog to populate it."
        />
      )}

      {(!collectionHero || pagination.totalPages > 1) && (
      <section class="flex flex-wrap items-center justify-between gap-4 border-t border-line/80 pt-5 text-sm">
        <div class="flex flex-wrap items-center gap-2">
          {previousPageHref ? (
            <a
              href={previousPageHref}
              class="blog-page-link text-muted hover:text-ink"
            >
              Previous
            </a>
          ) : (
            <span class="blog-page-link text-muted/50">Previous</span>
          )}

          {paginationLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'blog-page-number text-muted hover:text-ink',
                link.isCurrent && 'text-ink',
              ]}
            >
              {link.page}
            </a>
          ))}

          {nextPageHref ? (
            <a
              href={nextPageHref}
              class="blog-page-link text-muted hover:text-ink"
            >
              Next
            </a>
          ) : (
            <span class="blog-page-link text-muted/50">Next</span>
          )}
        </div>

        <p class="text-sm text-muted">
          {pagination.totalPages > 1 ? `${pagination.totalPages} pages total` : 'Single page'}
        </p>
      </section>
      )}
    </div>

    {!collectionHero && (
    <aside class="blog-sidebar space-y-8 lg:sticky lg:top-32">
      <section class="border-t border-line/80 pt-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="blog-side-heading">Collections</h2>
          <a href="/collection" class="text-xs text-muted hover:text-ink">All →</a>
        </div>

        <div class="mt-4 space-y-2">
          {collections.map((collection) => (
            <a
              href={collection.href}
              class:list={[
                'blog-sidebar-collection-card group/collection flex items-center justify-between gap-4 rounded-[1.05rem] border border-line/75 bg-card/70 px-4 py-3 transition hover:-translate-y-0.5 hover:border-accent/45 hover:bg-line/25',
                currentCollection === collection.label && 'border-accent/45 bg-line/35',
              ]}
            >
              <div class="min-w-0">
                <h3 class="truncate text-base font-medium leading-tight text-ink transition group-hover/collection:text-accent">
                  {collection.label}
                </h3>
                <p class="mt-1 line-clamp-2 text-xs leading-5 text-muted">
                  {collection.description ?? `${collection.count} posts in this collection.`}
                </p>
                {collection.description && (
                  <p class="mt-1 text-[0.68rem] leading-4 text-muted/70">{collection.count} posts</p>
                )}
              </div>
              <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-ink transition group-hover/collection:translate-x-1 group-hover/collection:text-accent">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="border-t border-line/80 pt-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="blog-side-heading">Tags</h2>
          <span class="text-sm text-muted">{tags.length}</span>
        </div>

        {tags.length > 0 ? (
          <div class="mt-4 flex flex-wrap gap-x-3 gap-y-2">
            {tags.map((tag) => (
              <a
                href={tag.href}
                class:list={[
                  'blog-collection-pill inline-flex items-center gap-1.5 rounded-full border border-line/75 px-3 py-1.5 text-sm text-muted transition hover:-translate-y-0.5 hover:border-accent/45 hover:text-ink',
                  currentTag === tag.tag && 'border-accent/45 bg-line/45 text-ink',
                ]}
              >
                <span>#{tag.tag}</span>
                <span class="text-xs text-muted/70">{tag.count}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-5 text-sm leading-7 text-muted">Add tags in blog frontmatter to populate this section.</p>
        )}
      </section>
    </aside>
    )}
  </div>
</BaseLayout>

<style>
  .blog-display-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-weight: 500;
    letter-spacing: -0.045em;
  }

  .blog-nav-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    border: 1px solid rgb(var(--color-line) / 0.85);
    border-radius: 9999px;
    color: rgb(var(--color-ink));
    background: transparent;
    transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .blog-nav-arrow:hover {
    color: rgb(var(--color-accent));
    border-color: rgb(var(--color-accent) / 0.45);
    transform: translateY(-1px);
  }

  .blog-nav-arrow-disabled {
    opacity: 0.35;
  }

  .blog-post-title,
  .blog-sidebar-collection-card h3,
  .blog-side-heading {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    letter-spacing: -0.03em;
  }

  .blog-side-heading {
    font-size: 1rem;
    font-weight: 500;
    color: rgb(var(--color-ink));
  }

  .blog-index-header-compact {
    margin-top: 0;
    padding-bottom: 1rem;
  }

  .collection-detail-hero {
    position: relative;
    overflow: hidden;
    min-height: 17rem;
    border: 1px solid rgb(var(--color-line) / 0.8);
    border-radius: 1.35rem;
    background: rgb(var(--color-card) / 0.76);
    box-shadow: var(--shadow-card);
  }

  .collection-detail-hero-image {
    display: block;
    width: 100%;
    height: clamp(17rem, 38vw, 24rem);
    object-fit: cover;
    filter: brightness(0.74);
    transition: transform 420ms ease, filter 260ms ease;
  }

  .collection-detail-hero:hover .collection-detail-hero-image {
    transform: scale(1.018);
    filter: brightness(0.82);
  }

  .collection-detail-hero-empty {
    display: flex;
    min-height: 17rem;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-muted));
    background:
      radial-gradient(circle at 18% 12%, rgb(var(--color-accent) / 0.12), transparent 32%),
      linear-gradient(135deg, rgb(var(--color-card) / 0.9), rgb(var(--color-line) / 0.2));
  }

  .collection-detail-hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.35rem;
    color: white;
    background: linear-gradient(to top, rgb(0 0 0 / 0.76), rgb(0 0 0 / 0.28) 48%, transparent);
  }

  .collection-detail-hero-title {
    max-width: 42rem;
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .collection-detail-hero-description {
    margin-top: 0.6rem;
    max-width: 38rem;
    font-size: 0.98rem;
    line-height: 1.75;
    color: rgb(255 255 255 / 0.86);
  }

  .blog-post-card::before {
    content: '';
    position: absolute;
    inset: 0 0 0 auto;
    width: 38%;
    pointer-events: none;
    background:
      radial-gradient(circle at right center, rgb(var(--color-line) / 0.38), transparent 62%),
      linear-gradient(90deg, rgb(var(--color-card) / 0), rgb(var(--color-line) / 0.2));
    opacity: 0.72;
  }

  .blog-post-card-with-cover::before {
    display: none;
  }

  .blog-post-card > * {
    position: relative;
    z-index: 1;
  }

  .blog-card-stretched-link {
    display: block;
    position: absolute !important;
    inset: 0;
    z-index: 2 !important;
    border-radius: inherit;
  }

  .blog-card-stretched-link:focus-visible {
    outline: 2px solid rgb(var(--color-accent) / 0.62);
    outline-offset: -5px;
  }

  .blog-card-content {
    position: relative;
    z-index: 3;
  }

  .blog-card-actions {
    position: relative;
    z-index: 4;
  }

  .blog-cover-image {
    display: block;
    position: absolute !important;
    top: 0;
    right: 0;
    bottom: 0;
    left: auto;
    z-index: 0;
    width: 58% !important;
    height: 100% !important;
    max-width: none;
    border-radius: inherit;
    object-fit: cover;
    opacity: 0.5;
    pointer-events: none;
    transition: opacity 260ms ease, transform 360ms ease;
    mask-image: linear-gradient(to right, transparent 0%, rgb(0 0 0 / 0.16) 18%, black 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgb(0 0 0 / 0.16) 18%, black 100%);
  }

  .blog-post-card-with-cover:hover .blog-cover-image {
    opacity: 0.68;
    transform: scale(1.015);
  }

  .blog-pill-button {
    display: inline-flex;
    align-items: center;
    min-height: 2.05rem;
    border: 1px solid rgb(var(--color-line) / 0.78);
    border-radius: 9999px;
    background: rgb(var(--color-paper) / 0.68);
    padding: 0.38rem 0.86rem;
    font-size: 0.8rem;
    line-height: 1;
    color: rgb(var(--color-muted));
    transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .blog-pill-button:hover,
  .blog-pill-button-active {
    border-color: rgb(var(--color-accent) / 0.45);
    background: rgb(var(--color-line) / 0.42);
    color: rgb(var(--color-ink));
    transform: translateY(-1px);
  }

  .blog-page-link,
  .blog-page-number {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
  }

  .blog-page-number {
    min-width: 1.35rem;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .blog-post-card {
      min-height: 13rem;
    }

    .blog-post-card-with-cover {
      padding-top: 6.5rem;
    }

    .blog-cover-image {
      top: 0;
      right: 0;
      bottom: auto;
      left: 0;
      width: 100% !important;
      height: 8rem !important;
      mask-image: linear-gradient(to top, transparent 0%, rgb(0 0 0 / 0.2) 28%, black 100%);
      -webkit-mask-image: linear-gradient(to top, transparent 0%, rgb(0 0 0 / 0.2) 28%, black 100%);
    }
  }
 </style>
