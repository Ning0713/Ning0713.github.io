---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from './EmptyState.astro';
import { SITE_TITLE } from '../consts';
import type { BlogCollectionOverview, BlogPaginationResult, BlogTagOverview } from '../lib/blog';
import { getBlogTagPageHref } from '../lib/blog';
import { formatDate } from '../lib/content';

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  pagination: BlogPaginationResult;
  collections: BlogCollectionOverview[];
  tags: BlogTagOverview[];
  paginationLinks: { page: number; href: string; isCurrent: boolean }[];
  currentSectionLabel?: string;
  currentCollection?: string;
  currentTag?: string;
}

const {
  title,
  description,
  eyebrow,
  pagination,
  collections,
  tags,
  paginationLinks,
  currentSectionLabel,
  currentCollection,
  currentTag,
} = Astro.props;

const pageTitle = `${title} | ${SITE_TITLE}`;
const hasPosts = pagination.posts.length > 0;
const previousPageHref = pagination.page > 1 ? paginationLinks[pagination.page - 2]?.href : null;
const nextPageHref = pagination.page < pagination.totalPages ? paginationLinks[pagination.page]?.href : null;
const currentCollectionIndex = currentCollection ? collections.findIndex((item) => item.label === currentCollection) : -1;
const previousCollection = currentCollectionIndex > 0 ? collections[currentCollectionIndex - 1] : null;
const nextCollection =
  currentCollectionIndex >= 0 && currentCollectionIndex < collections.length - 1
    ? collections[currentCollectionIndex + 1]
    : null;
---

<BaseLayout title={pageTitle} description={description}>
  <header class="mb-12 border-b border-line/80 pb-8">
    <p class="text-sm tracking-[0.08em] text-muted">{eyebrow}</p>

    <div class="mt-5 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-4xl">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="blog-display-title text-5xl leading-none text-ink sm:text-6xl">{title}</h1>
          {currentCollection && (
            <div class="flex items-center gap-2 pt-1">
              {previousCollection ? (
                <a
                  href={previousCollection.href}
                  aria-label={`Go to ${previousCollection.label}`}
                  class="blog-nav-arrow"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M12.78 4.22a.75.75 0 0 1 0 1.06L8.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06l-5.25-5.25a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              ) : (
                <span class="blog-nav-arrow blog-nav-arrow-disabled" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M12.78 4.22a.75.75 0 0 1 0 1.06L8.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06l-5.25-5.25a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              )}

              {nextCollection ? (
                <a
                  href={nextCollection.href}
                  aria-label={`Go to ${nextCollection.label}`}
                  class="blog-nav-arrow"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              ) : (
                <span class="blog-nav-arrow blog-nav-arrow-disabled" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              )}
            </div>
          )}
        </div>
        <p class="mt-5 max-w-3xl text-base leading-8 text-muted sm:text-lg">{description}</p>
      </div>

      <div class="text-sm text-muted lg:text-right">
        {currentTag ? (
          <p>标签页</p>
        ) : (
          <a href="/collection" class="inline-flex items-center gap-2 hover:text-ink">
            <span>查看全部分类</span>
            <span aria-hidden="true">→</span>
          </a>
        )}
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-3 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
      <p>
        Page {pagination.page} - Showing {pagination.endIndex} of {pagination.totalPosts} posts
      </p>
      {currentTag ? (
        <p>
          当前标签: <span class="font-semibold text-ink">#{currentTag}</span>
        </p>
      ) : currentCollection ? (
        <p>
          当前分类: <span class="font-semibold text-ink">{currentCollection}</span>
        </p>
      ) : currentSectionLabel ? (
        <p>
          当前栏目: <span class="font-semibold text-ink">{currentSectionLabel}</span>
        </p>
      ) : null}
    </div>
  </header>

  <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_17rem] lg:items-start">
    <div class="space-y-8">
      {hasPosts ? (
        <ul class="border-t border-line/80">
          {pagination.posts.map((post: CollectionEntry<'blog'>) => (
            <li class="border-b border-line/70 py-6">
              <a href={`/blog/${post.slug}`} class="block group/post">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-muted">
                  <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                  <span aria-hidden="true">/</span>
                  <span>{post.data.collection}</span>
                </div>
                <h2 class="mt-3 text-2xl font-semibold tracking-tight text-ink transition group-hover/post:text-accent">
                  {post.data.title}
                </h2>
                <p class="mt-3 max-w-reading text-base leading-8 text-muted">
                  {post.data.description}
                </p>
              </a>

              {post.data.tags.length > 0 && (
                <ul class="mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <li>
                      <a
                        href={getBlogTagPageHref(tag)}
                        class:list={[
                          'inline-flex items-center rounded-full border border-line/70 px-3 py-1 text-xs text-muted hover:border-accent/50 hover:text-ink',
                          currentTag === tag && 'border-accent/50 bg-line/50 text-ink',
                        ]}
                      >
                        #{tag}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <EmptyState
          title="No posts yet"
          description="This route is ready. Add matching MD or MDX files under src/content/blog to populate it."
        />
      )}

      <section class="flex flex-wrap items-center justify-between gap-4 border-t border-line/80 pt-5">
        <div class="flex flex-wrap items-center gap-2">
          {previousPageHref ? (
            <a
              href={previousPageHref}
              class="rounded-full border border-line/80 px-3 py-1.5 text-sm text-muted hover:border-accent/50 hover:text-ink"
            >
              Previous
            </a>
          ) : (
            <span class="rounded-full border border-line/60 px-3 py-1.5 text-sm text-muted/55">Previous</span>
          )}

          {paginationLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'rounded-full border border-line/80 px-3 py-1.5 text-sm text-muted hover:border-accent/50 hover:text-ink',
                link.isCurrent && 'border-accent/50 bg-line/50 text-ink',
              ]}
            >
              {link.page}
            </a>
          ))}

          {nextPageHref ? (
            <a
              href={nextPageHref}
              class="rounded-full border border-line/80 px-3 py-1.5 text-sm text-muted hover:border-accent/50 hover:text-ink"
            >
              Next
            </a>
          ) : (
            <span class="rounded-full border border-line/60 px-3 py-1.5 text-sm text-muted/55">Next</span>
          )}
        </div>

        <p class="text-sm text-muted">
          {pagination.totalPages > 1 ? `${pagination.totalPages} pages total` : 'Single page'}
        </p>
      </section>
    </div>

    <aside class="space-y-8 lg:sticky lg:top-32">
      <section class="border-t border-line/80 pt-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="blog-side-heading">分类</h2>
          <a href="/collection" class="text-sm text-muted hover:text-ink">查看全部 →</a>
        </div>

        <div class="mt-5 space-y-3">
          {collections.map((collection) => (
            <a
              href={collection.href}
              class:list={[
                'block rounded-2xl border border-line/70 px-4 py-3 transition hover:border-accent/50 hover:bg-line/30',
                currentCollection === collection.label && 'border-accent/50 bg-line/40',
              ]}
            >
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="text-sm font-semibold text-ink">{collection.label}</h3>
                </div>
                <span class="rounded-full border border-line/70 px-2.5 py-1 text-xs text-muted">
                  {collection.count}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="border-t border-line/80 pt-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="blog-side-heading">标签</h2>
          <span class="text-sm text-muted">{tags.length}</span>
        </div>

        {tags.length > 0 ? (
          <div class="mt-5 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={tag.href}
                class:list={[
                  'inline-flex items-center gap-2 rounded-full border border-line/80 px-3 py-1.5 text-sm text-muted hover:border-accent/50 hover:text-ink',
                  currentTag === tag.tag && 'border-accent/50 bg-line/50 text-ink',
                ]}
              >
                <span>#{tag.tag}</span>
                <span class="text-xs text-muted/80">{tag.count}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-5 text-sm leading-7 text-muted">Add tags in blog frontmatter to populate this section.</p>
        )}
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  .blog-display-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-weight: 500;
    letter-spacing: -0.06em;
  }

  .blog-nav-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid rgb(var(--color-line) / 0.85);
    border-radius: 9999px;
    color: rgb(var(--color-ink));
    background: rgb(var(--color-paper) / 0.62);
    transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .blog-nav-arrow:hover {
    color: rgb(var(--color-accent));
    border-color: rgb(var(--color-accent) / 0.45);
    transform: translateY(-1px);
  }

  .blog-nav-arrow-disabled {
    opacity: 0.35;
  }

  .blog-side-heading {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: rgb(var(--color-ink));
  }
 </style>
