---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from './EmptyState.astro';
import { BLOG_CATEGORY_ITEMS, SITE_TITLE } from '../consts';
import type { BlogCollectionOverview, BlogPaginationResult, BlogTagOverview } from '../lib/blog';
import { getBlogCategoryPageHref, getBlogTagPageHref } from '../lib/blog';
import { formatDate } from '../lib/content';
import { countReadableWords } from '../lib/stats';

interface Props {
  title: string;
  description: string;
  pagination: BlogPaginationResult;
  collections: BlogCollectionOverview[];
  tags: BlogTagOverview[];
  paginationLinks: { page: number; href: string; isCurrent: boolean }[];
  currentSectionLabel?: string;
  currentCollection?: string;
  currentTag?: string;
}

const {
  title,
  description,
  pagination,
  collections,
  tags,
  paginationLinks,
  currentSectionLabel,
  currentCollection,
  currentTag,
} = Astro.props;

const pageTitle = `${title} | ${SITE_TITLE}`;
const hasPosts = pagination.posts.length > 0;
const previousPageHref = pagination.page > 1 ? paginationLinks[pagination.page - 2]?.href : null;
const nextPageHref = pagination.page < pagination.totalPages ? paginationLinks[pagination.page]?.href : null;
const currentCollectionIndex = currentCollection ? collections.findIndex((item) => item.label === currentCollection) : -1;
const previousCollection = currentCollectionIndex > 0 ? collections[currentCollectionIndex - 1] : null;
const nextCollection =
  currentCollectionIndex >= 0 && currentCollectionIndex < collections.length - 1
    ? collections[currentCollectionIndex + 1]
    : null;
const currentCategoryIndex =
  currentSectionLabel && !currentCollection && !currentTag
    ? BLOG_CATEGORY_ITEMS.findIndex((item) => item.label === currentSectionLabel)
    : -1;
const previousCategory = currentCategoryIndex > 0 ? BLOG_CATEGORY_ITEMS[currentCategoryIndex - 1] : null;
const nextCategory =
  currentCategoryIndex >= 0 && currentCategoryIndex < BLOG_CATEGORY_ITEMS.length - 1
    ? BLOG_CATEGORY_ITEMS[currentCategoryIndex + 1]
    : null;
const previousNavItem = previousCollection
  ? { href: previousCollection.href, label: previousCollection.label }
  : previousCategory
    ? { href: getBlogCategoryPageHref(previousCategory.slug), label: previousCategory.label }
    : null;
const nextNavItem = nextCollection
  ? { href: nextCollection.href, label: nextCollection.label }
  : nextCategory
    ? { href: getBlogCategoryPageHref(nextCategory.slug), label: nextCategory.label }
    : null;

const getReadingMinutes = (post: CollectionEntry<'blog'>) => {
  const words = countReadableWords([post.data.title, post.data.description, post.body ?? ''].join(' '));
  return Math.max(1, Math.ceil(words / 420));
};
---

<BaseLayout title={pageTitle} description={description}>
  <header class="blog-index-header mb-10 border-b border-line/80 pb-7">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="blog-display-title text-4xl leading-none text-ink sm:text-5xl">{title}</h1>

        {(currentCollection || currentCategoryIndex >= 0) && (
          <div class="flex items-center gap-2 pt-1">
            {previousNavItem ? (
              <a
                href={previousNavItem.href}
                aria-label={`Go to ${previousNavItem.label}`}
                class="blog-nav-arrow"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M12.78 4.22a.75.75 0 0 1 0 1.06L8.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06l-5.25-5.25a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
            ) : (
              <span class="blog-nav-arrow blog-nav-arrow-disabled" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-4 w-4"
                >
                  <path
                    fill-rule="evenodd"
                    d="M12.78 4.22a.75.75 0 0 1 0 1.06L8.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06l-5.25-5.25a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
            )}

            {nextNavItem ? (
              <a
                href={nextNavItem.href}
                aria-label={`Go to ${nextNavItem.label}`}
                class="blog-nav-arrow"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
            ) : (
              <span class="blog-nav-arrow blog-nav-arrow-disabled" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-4 w-4"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
            )}
          </div>
        )}
      </div>

      <p class="text-sm leading-6 text-muted sm:text-right">
        Page {pagination.page} of {pagination.totalPages} · Showing {pagination.startIndex}-{pagination.endIndex} of {pagination.totalPosts}
      </p>
    </div>

    <div class="mt-6 flex flex-col gap-3 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
      <a href="/collection" class="inline-flex w-fit items-center gap-2 hover:text-ink">
        <span>View all posts by collections</span>
        <span aria-hidden="true">→</span>
      </a>
      {currentTag ? (
        <p>
          当前标签: <span class="font-semibold text-ink">#{currentTag}</span>
        </p>
      ) : currentCollection ? (
        <p>
          当前分类: <span class="font-semibold text-ink">{currentCollection}</span>
        </p>
      ) : currentSectionLabel ? (
        <p>
          当前栏目: <span class="font-semibold text-ink">{currentSectionLabel}</span>
        </p>
      ) : null}
    </div>
  </header>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_15.5rem] lg:items-start">
    <div class="space-y-8">
      {hasPosts ? (
        <ul class="blog-post-list border-t border-line/80">
          {pagination.posts.map((post: CollectionEntry<'blog'>) => (
            <li class="blog-post-item border-b border-line/70 py-7">
              <a href={`/blog/${post.slug}`} class="group/post grid gap-3 sm:grid-cols-[8.5rem_minmax(0,1fr)]">
                <time class="blog-post-date text-sm leading-7 text-muted" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>

                <div>
                  <h2 class="blog-post-title text-xl font-medium leading-snug text-ink transition group-hover/post:text-accent sm:text-2xl">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 max-w-reading text-sm leading-7 text-muted sm:text-[0.95rem]">
                    {post.data.description}
                  </p>
                  <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-muted">
                    <span>{post.data.collection}</span>
                    <span aria-hidden="true">/</span>
                    <span>{getReadingMinutes(post)} min read</span>
                  </div>
                </div>
              </a>

              {post.data.tags.length > 0 && (
                <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-2 sm:ml-[8.5rem]">
                  {post.data.tags.map((tag) => (
                    <li>
                      <a
                        href={getBlogTagPageHref(tag)}
                        class:list={[
                          'blog-inline-tag text-xs text-muted hover:text-ink',
                          currentTag === tag && 'text-ink',
                        ]}
                      >
                        #{tag}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <EmptyState
          title="No posts yet"
          description="This route is ready. Add matching MD or MDX files under src/content/blog to populate it."
        />
      )}

      <section class="flex flex-wrap items-center justify-between gap-4 border-t border-line/80 pt-5 text-sm">
        <div class="flex flex-wrap items-center gap-2">
          {previousPageHref ? (
            <a
              href={previousPageHref}
              class="blog-page-link text-muted hover:text-ink"
            >
              Previous
            </a>
          ) : (
            <span class="blog-page-link text-muted/50">Previous</span>
          )}

          {paginationLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'blog-page-number text-muted hover:text-ink',
                link.isCurrent && 'text-ink',
              ]}
            >
              {link.page}
            </a>
          ))}

          {nextPageHref ? (
            <a
              href={nextPageHref}
              class="blog-page-link text-muted hover:text-ink"
            >
              Next
            </a>
          ) : (
            <span class="blog-page-link text-muted/50">Next</span>
          )}
        </div>

        <p class="text-sm text-muted">
          {pagination.totalPages > 1 ? `${pagination.totalPages} pages total` : 'Single page'}
        </p>
      </section>
    </div>

    <aside class="blog-sidebar space-y-9 lg:sticky lg:top-32">
      <section class="border-t border-line/80 pt-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="blog-side-heading">Collections</h2>
          <a href="/collection" class="text-xs text-muted hover:text-ink">All →</a>
        </div>

        <div class="mt-4 divide-y divide-line/70">
          {collections.map((collection) => (
            <a
              href={collection.href}
              class:list={[
                'blog-index-link flex items-baseline justify-between gap-3 py-2.5 text-sm hover:text-ink',
                currentCollection === collection.label ? 'text-ink' : 'text-muted',
              ]}
            >
              <span>{collection.label}</span>
              <span class="text-xs text-muted">{collection.count}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="border-t border-line/80 pt-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="blog-side-heading">Tags</h2>
          <span class="text-sm text-muted">{tags.length}</span>
        </div>

        {tags.length > 0 ? (
          <div class="mt-4 flex flex-wrap gap-x-3 gap-y-2">
            {tags.map((tag) => (
              <a
                href={tag.href}
                class:list={[
                  'blog-inline-tag inline-flex items-center gap-1.5 text-sm text-muted hover:text-ink',
                  currentTag === tag.tag && 'text-ink',
                ]}
              >
                <span>#{tag.tag}</span>
                <span class="text-xs text-muted/70">{tag.count}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-5 text-sm leading-7 text-muted">Add tags in blog frontmatter to populate this section.</p>
        )}
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  .blog-display-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-weight: 500;
    letter-spacing: -0.045em;
  }

  .blog-nav-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.85rem;
    height: 1.85rem;
    border: 1px solid rgb(var(--color-line) / 0.85);
    border-radius: 9999px;
    color: rgb(var(--color-ink));
    background: transparent;
    transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .blog-nav-arrow:hover {
    color: rgb(var(--color-accent));
    border-color: rgb(var(--color-accent) / 0.45);
    transform: translateY(-1px);
  }

  .blog-nav-arrow-disabled {
    opacity: 0.35;
  }

  .blog-post-title,
  .blog-side-heading {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    letter-spacing: -0.03em;
  }

  .blog-side-heading {
    font-size: 1rem;
    font-weight: 500;
    color: rgb(var(--color-ink));
  }

  .blog-inline-tag {
    text-underline-offset: 0.18rem;
  }

  .blog-inline-tag:hover {
    text-decoration: underline;
  }

  .blog-page-link,
  .blog-page-number {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
  }

  .blog-page-number {
    min-width: 1.35rem;
    justify-content: center;
  }
 </style>
