---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="mb-10 space-y-4 border-b border-line/80 pb-8">
  {eyebrow && (
    <p class="eyebrow-label">
      {eyebrow}
    </p>
  )}
  <div class="max-w-3xl space-y-3">
    <h1 class="font-serif text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      {title}
    </h1>
    <p class="text-base leading-8 text-muted sm:text-lg">
      {description}
    </p>
  </div>
</header>
