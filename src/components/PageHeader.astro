---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="mb-8 space-y-3 border-b border-line/80 pb-6">
  {eyebrow && (
    <p class="eyebrow-label">
      {eyebrow}
    </p>
  )}
  <div class="max-w-3xl space-y-3">
    <h1 class="page-header-title text-3xl font-medium leading-tight text-ink sm:text-4xl">
      {title}
    </h1>
    <p class="text-sm leading-7 text-muted sm:text-base">
      {description}
    </p>
  </div>
</header>

<style>
  .page-header-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    letter-spacing: -0.035em;
  }
</style>
