---
import { formatDate } from '../lib/content';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  meta?: string;
  tagHrefBuilder?: ((tag: string) => string) | null;
}

const { href, title, description, date, tags = [], meta, tagHrefBuilder = null } = Astro.props;
---

<article class="collection-preview-card group relative overflow-hidden rounded-[1.6rem] border border-line/80 bg-card/72 p-5 shadow-card transition duration-300 hover:-translate-y-0.5 hover:border-accent/45 sm:p-6">
  <a href={href} class="block pr-10">
    <div class="flex flex-wrap items-center gap-2 text-xs leading-6 text-muted">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {meta && (
        <>
          <span aria-hidden="true">/</span>
          <span>{meta}</span>
        </>
      )}
    </div>
    <h2 class="collection-preview-title mt-2 text-xl font-medium leading-snug text-ink transition group-hover:text-accent sm:text-2xl">
      {title}
    </h2>
    <p class="mt-2 text-sm leading-7 text-muted sm:text-base">
      {description}
    </p>
    <span class="collection-preview-arrow absolute right-5 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full text-ink transition group-hover:translate-x-1 group-hover:text-accent">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M7.22 15.78a.75.75 0 0 1 0-1.06L11.94 10 7.22 5.28a.75.75 0 0 1 1.06-1.06l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 0 1-1.06 0Z"
          clip-rule="evenodd"
        />
      </svg>
    </span>
  </a>
  {tags.length > 0 && (
    <ul class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <li>
          {tagHrefBuilder ? (
            <a
              href={tagHrefBuilder(tag)}
              class="collection-preview-pill"
            >
              #{tag}
            </a>
          ) : (
            <span class="collection-preview-pill">
              #{tag}
            </span>
          )}
        </li>
      ))}
    </ul>
  )}
</article>

<style>
  .collection-preview-card::before {
    content: '';
    position: absolute;
    inset: 0 0 0 auto;
    width: 35%;
    pointer-events: none;
    background:
      radial-gradient(circle at right center, rgb(var(--color-line) / 0.28), transparent 62%),
      linear-gradient(90deg, rgb(var(--color-card) / 0), rgb(var(--color-line) / 0.15));
    opacity: 0.8;
  }

  .collection-preview-card > * {
    position: relative;
    z-index: 1;
  }

  .collection-preview-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    letter-spacing: -0.03em;
  }

  .collection-preview-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2.1rem;
    border: 1px solid rgb(var(--color-line) / 0.78);
    border-radius: 9999px;
    background: rgb(var(--color-paper) / 0.68);
    padding: 0.4rem 0.9rem;
    font-size: 0.78rem;
    line-height: 1;
    color: rgb(var(--color-muted));
    transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .collection-preview-pill:hover {
    border-color: rgb(var(--color-accent) / 0.45);
    background: rgb(var(--color-line) / 0.42);
    color: rgb(var(--color-ink));
    transform: translateY(-1px);
  }
</style>
