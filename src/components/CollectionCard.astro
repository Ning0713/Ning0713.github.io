---
import { formatDate } from '../lib/content';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  meta?: string;
  tagHrefBuilder?: ((tag: string) => string) | null;
}

const { href, title, description, date, tags = [], meta, tagHrefBuilder = null } = Astro.props;
---

<article class="surface-card group rounded-3xl border border-line/80 p-6 shadow-card transition duration-300 hover:-translate-y-1 hover:border-accent/50">
  <a href={href} class="block">
    <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-muted">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {meta && (
        <>
          <span aria-hidden="true">/</span>
          <span>{meta}</span>
        </>
      )}
    </div>
    <h2 class="text-xl font-bold tracking-tight text-ink group-hover:text-accent">
      {title}
    </h2>
    <p class="mt-3 leading-7 text-muted">
      {description}
    </p>
  </a>
  {tags.length > 0 && (
    <ul class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <li>
          {tagHrefBuilder ? (
            <a
              href={tagHrefBuilder(tag)}
              class="rounded-full border border-line/70 px-3 py-1 text-xs text-muted hover:border-accent/50 hover:text-ink"
            >
              #{tag}
            </a>
          ) : (
            <span class="rounded-full border border-line/70 px-3 py-1 text-xs text-muted">
              #{tag}
            </span>
          )}
        </li>
      ))}
    </ul>
  )}
</article>
