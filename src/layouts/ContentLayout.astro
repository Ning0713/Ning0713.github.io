---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { SITE_TITLE } from '../consts';
import { getBlogTagPageHref } from '../lib/blog';
import { formatDate } from '../lib/content';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  collectionLabel?: string;
  cover?: string;
  coverAlt?: string;
  coverSource?: string;
  readingMinutes?: number;
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  collectionLabel,
  cover,
  coverAlt,
  coverSource,
  readingMinutes,
  headings = [],
} = Astro.props;
const tocItems = headings.filter((heading) => heading.depth >= 1 && heading.depth <= 4);
const hasToc = tocItems.length > 0;
const coverUrl = cover?.trim() ?? '';
const hasArticleHero = coverUrl.length > 0;
const coverAltText = coverAlt?.trim() || title;
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
  <article class="mx-auto w-full max-w-6xl">
    <div class="lg:grid lg:grid-cols-[minmax(0,44rem)_16rem] lg:gap-12">
      <div>
        {hasArticleHero ? (
          <header class="article-hero mb-6">
            <img
              src={coverUrl}
              alt=""
              class="article-hero-bg"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              aria-hidden="true"
              data-article-hero-blur
            />
            <div class="article-hero-image-frame">
              <img
                src={coverUrl}
                alt={coverAltText}
                class="article-hero-cover"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
              <img
                src={coverUrl}
                alt=""
                class="article-hero-edge-blur"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                aria-hidden="true"
              />
            </div>

            <div class="article-hero-meta">
              <time class="article-hero-meta-item" datetime={date.toISOString()}>
                <svg class="article-hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v4M16 2v4M3.5 9.5h17M5.5 4h13A2.5 2.5 0 0 1 21 6.5v12A2.5 2.5 0 0 1 18.5 21h-13A2.5 2.5 0 0 1 3 18.5v-12A2.5 2.5 0 0 1 5.5 4Z" />
                </svg>
                <span>{formatDate(date)}</span>
                {updatedDate && (
                  <span class="article-hero-update">
                    / Update {formatDate(updatedDate)}
                  </span>
                )}
              </time>

              {readingMinutes && (
                <span class="article-hero-meta-item">
                  <svg class="article-hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 2" />
                  </svg>
                  <span>{readingMinutes} min read</span>
                </span>
              )}

              <span class="article-hero-meta-item">
                <svg class="article-hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3a9 9 0 1 0 9 9 6 6 0 0 1-9-9Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 4v4M21 6h-4" />
                </svg>
                {coverSource ? (
                  <a href={coverSource} target="_blank" rel="noreferrer" class="article-hero-meta-link">
                    Hero Image
                  </a>
                ) : (
                  <span>Hero Image</span>
                )}
              </span>

              {tags.length > 0 && (
                <span class="article-hero-meta-item article-hero-tags">
                  <svg class="article-hero-icon article-hero-hash-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path stroke-linecap="round" d="M10 3 8 21M16 3l-2 18M4 9h17M3 15h17" />
                  </svg>
                  {tags.map((tag, index) => (
                    <Fragment>
                      <a href={getBlogTagPageHref(tag)} class="article-hero-meta-link">{tag}</a>
                      {index < tags.length - 1 && <span class="article-hero-tag-separator">/</span>}
                    </Fragment>
                  ))}
                </span>
              )}
            </div>

            <h1 class="article-hero-title">
              {title}
            </h1>
            <blockquote class="article-hero-description">
              <q>{description}</q>
            </blockquote>
            <slot name="meta" />
            <div class="article-hero-divider" aria-hidden="true"></div>
          </header>
        ) : (
          <header class="mb-9 border-b border-line/80 pb-7">
            {collectionLabel && (
              <p class="content-meta-pill w-fit">
                {collectionLabel}
              </p>
            )}
            <h1 class="content-detail-title mt-4 text-3xl font-medium leading-tight text-ink sm:text-4xl">
              {title}
            </h1>
            <p class="mt-4 max-w-reading text-sm leading-7 text-muted sm:text-base">{description}</p>
            <div class="mt-5 flex flex-wrap items-center gap-2 text-sm text-muted">
              <time class="content-meta-pill" datetime={date.toISOString()}>{formatDate(date)}</time>
              {tags.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <li class="content-meta-pill">
                      #{tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <slot name="meta" />
          </header>
        )}

        {hasToc && (
          <div class="mb-10 lg:hidden">
            <TableOfContents items={tocItems} />
          </div>
        )}

        <div class="content-prose prose prose-slate max-w-none dark:prose-invert">
          <slot />
        </div>
      </div>

      {hasToc && (
        <aside class="hidden lg:block lg:sticky lg:top-32 lg:self-start">
          <TableOfContents items={tocItems} />
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .content-detail-title {
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    letter-spacing: -0.035em;
  }

  .content-meta-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    border: 1px solid rgb(var(--color-line) / 0.78);
    border-radius: 9999px;
    background: rgb(var(--color-card) / 0.72);
    padding: 0.35rem 0.85rem;
    font-size: 0.78rem;
    line-height: 1;
    color: rgb(var(--color-muted));
  }

  .article-hero {
    position: relative;
    isolation: isolate;
    color: rgb(var(--color-ink));
  }

  .article-hero > :not(.article-hero-bg) {
    position: relative;
    z-index: 1;
  }

  .article-hero-bg {
    position: absolute;
    inset-block-start: -4.25rem;
    inset-inline-start: -4rem;
    z-index: 0;
    width: calc(100% + 23rem);
    height: 30rem;
    border-radius: 2.5rem;
    object-fit: cover;
    opacity: 0.24;
    filter: blur(54px) saturate(1.18);
    transform: scale(1.04);
    pointer-events: none;
    transition: opacity 240ms ease;
    mask-image: linear-gradient(
      to bottom,
      rgb(0 0 0 / 0.95) 0%,
      rgb(0 0 0 / 0.82) 45%,
      rgb(0 0 0 / 0.35) 76%,
      transparent 100%
    );
  }

  .article-hero-image-frame {
    position: relative;
    width: min(100%, 60ch);
    margin-bottom: 1rem;
  }

  .article-hero-cover,
  .article-hero-edge-blur {
    max-height: 21rem;
    object-fit: contain;
  }

  .article-hero-cover {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 16px 44px -34px rgba(15, 23, 42, 0.5);
  }

  .article-hero-edge-blur {
    position: absolute;
    inset-inline-end: 0;
    top: 0.9rem;
    z-index: 0;
    width: 100%;
    height: 100%;
    border-radius: 1.35rem;
    filter: blur(20px);
    opacity: 0.36;
    transform: scale(1.025);
  }

  .article-hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 1.15rem;
    color: rgb(var(--color-muted));
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .article-hero-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
  }

  .article-hero-icon {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
    opacity: 0.82;
  }

  .article-hero-hash-icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .article-hero-update {
    white-space: nowrap;
  }

  .article-hero-tags {
    flex-wrap: wrap;
  }

  .article-hero-meta-link {
    color: inherit;
    text-decoration: none;
  }

  .article-hero-meta-link:hover {
    color: rgb(var(--color-accent));
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  .article-hero-tag-separator {
    opacity: 0.72;
  }

  .article-hero-title {
    margin-top: 1.2rem;
    font-family: 'Avenir Next', 'Helvetica Neue', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.22;
    letter-spacing: -0.015em;
  }

  .article-hero-description {
    margin-top: 0.65rem;
    border-left: 0;
    padding-left: 0;
    color: rgb(var(--color-muted));
    font-size: 0.9rem;
    font-style: italic;
    line-height: 1.65;
  }

  .article-hero-description q {
    quotes: '“' '”' '‘' '’';
  }

  .article-hero-divider {
    margin-top: 1rem;
    width: min(12rem, 42%);
    border-top: 1px solid rgb(var(--color-line) / 0.85);
  }

  @media (min-width: 640px) {
    .article-hero-title {
      font-size: 2.3rem;
    }
  }

  @media (max-width: 640px) {
    .article-hero-bg {
      inset-block-start: -2.5rem;
      inset-inline-start: -2rem;
      width: calc(100% + 4rem);
      height: 21rem;
      opacity: 0.2;
      filter: blur(38px) saturate(1.12);
    }

    .article-hero-image-frame {
      width: 100%;
      margin-bottom: 0.9rem;
    }

    .article-hero-title {
      font-size: 1.72rem;
    }

    .article-hero-meta {
      gap: 0.45rem 0.9rem;
      font-size: 0.82rem;
    }
  }
</style>

<script>
  const blurImage = document.querySelector('[data-article-hero-blur]') as HTMLImageElement | null;

  if (blurImage) {
    const viewportHeight = window.innerHeight;
    const thresholds = [viewportHeight / 9, (viewportHeight * 2) / 9, (viewportHeight * 3) / 9];
    let ticking = false;

    const syncBlurOpacity = () => {
      const scrollDistance = window.scrollY || document.documentElement.scrollTop || 0;

      if (scrollDistance >= thresholds[2]) {
        blurImage.style.opacity = '0.08';
      } else if (scrollDistance >= thresholds[1]) {
        blurImage.style.opacity = '0.13';
      } else if (scrollDistance >= thresholds[0]) {
        blurImage.style.opacity = '0.18';
      } else {
        blurImage.style.opacity = '0.24';
      }

      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (ticking) {
          return;
        }

        ticking = true;
        window.requestAnimationFrame(syncBlurOpacity);
      },
      { passive: true },
    );
  }
</script>
