---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { BLOG_CATEGORY_ITEMS, NAV_ITEMS, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';
import { getBlogCategoryPageHref } from '../lib/blog';

interface Props {
  title?: string;
  description?: string;
  highlightColor?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  highlightColor,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isHomePage = pathname === '/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const shouldUseDark = storedTheme === 'dark' || (!storedTheme && prefersDark);
        document.documentElement.classList.toggle('dark', shouldUseDark);
      })();
    </script>
  </head>
  <body class:list={[isHomePage ? 'is-home-page' : 'is-inner-page']}>
    {highlightColor && (
      <div
        id="highlight-gradient"
        class="site-highlight-gradient"
        style={`background-image: linear-gradient(${highlightColor}, transparent);`}
        aria-hidden="true"
      />
    )}

    <div class="relative z-10 mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 sm:px-8 lg:px-10">
      <header class="site-header" data-site-header data-scrolled="false">
        <div class="site-header-shell">
          <div class="site-header-row">
            <div class="site-brand">
              <a href="/" class="site-brand-link">
              <span class="font-serif">{SITE_TITLE}'s Blog</span>
              </a>
              <p
                class="site-motto text-xs font-normal italic leading-7 text-muted sm:text-sm"
                style="font-family: 'Times New Roman', Times, serif;"
              >
                C&apos;est une grande habilet&eacute; que de savoir cacher son habilet&eacute;.
              </p>
            </div>

            <div class="site-header-actions">
              <nav aria-label="Primary navigation" class="site-primary-nav">
                <ul class="site-primary-nav-list">
                  {NAV_ITEMS.map((item: (typeof NAV_ITEMS)[number]) => {
                    const isBlogSection = pathname === '/blog' || pathname.startsWith('/blog/');
                    const isActive =
                      item.href === '/blog'
                        ? isBlogSection
                        : pathname === item.href || pathname.startsWith(`${item.href}/`);
                    if (item.href === '/blog') {
                      return (
                        <li class="relative">
                          <div
                            class:list={[
                              'site-blog-nav-wrap inline-flex items-center rounded-full border border-line/80',
                              isBlogSection && 'site-blog-nav-active bg-white/15 text-white',
                            ]}
                          >
                            <a
                              href="/blog"
                              class="site-blog-link pl-3 pr-1.5 py-1.5 hover:text-white"
                            >
                              {item.label}
                            </a>
                            <details class="blog-nav-dropdown group relative">
                              <summary class="site-blog-summary blog-nav-summary inline-flex items-center justify-center px-1.5 py-1.5 hover:text-white">
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  viewBox="0 0 20 20"
                                  fill="currentColor"
                                  class="site-blog-chevron h-4 w-4 text-white transition group-open:rotate-180"
                                  aria-hidden="true"
                                >
                                  <path
                                    fill-rule="evenodd"
                                    d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                                    clip-rule="evenodd"
                                  />
                                </svg>
                              </summary>

                              <div class="absolute right-0 z-20 mt-2 w-52 rounded-2xl border border-line/80 bg-paper/95 p-2 text-black shadow-card backdrop-blur dark:text-ink">
                                {BLOG_CATEGORY_ITEMS.map((blogItem) => {
                                  const categoryHref = getBlogCategoryPageHref(blogItem.slug);
                                  const categoryActive =
                                    blogItem.slug === 'technical'
                                      ? pathname === '/blog' ||
                                        pathname.startsWith('/blog/page/') ||
                                        pathname === '/blog/category/technical' ||
                                        pathname.startsWith('/blog/category/technical/')
                                      : pathname === categoryHref || pathname.startsWith(`${categoryHref}/`);
                                  return (
                                    <a
                                      href={categoryHref}
                                      class:list={[
                                        'site-blog-category-link block rounded-xl px-3 py-2 text-sm text-black hover:bg-line/60 hover:text-black dark:text-ink dark:hover:text-ink',
                                        categoryActive && 'bg-line/60 text-black dark:text-ink',
                                      ]}
                                    >
                                      {blogItem.label}
                                    </a>
                                  );
                                })}
                              </div>
                            </details>
                          </div>
                        </li>
                      );
                    }
                    return (
                      <li>
                        <a
                          href={item.href}
                          class:list={[
                            'site-nav-link rounded-full px-3 py-1.5 hover:text-white',
                            isActive && 'site-nav-link-active bg-white/15 text-white',
                          ]}
                        >
                          {item.label}
                        </a>
                      </li>
                    );
                  })}
                  <li class="site-theme-toggle-slot">
                    <ThemeToggle />
                  </li>
                </ul>
              </nav>
            </div>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="mt-16 border-t border-line/80 pt-6 text-sm text-muted">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <p class="font-bold text-ink" style="font-family: 'Times New Roman', Times, serif;">Astro theme powered</p>
          <a
            href="https://github.com/Ning0713"
            target="_blank"
            rel="noreferrer"
            aria-label="Ning0713 on GitHub"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-line/80 text-ink transition hover:border-accent/50 hover:text-accent"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.41-4.04-1.41-.55-1.37-1.33-1.73-1.33-1.73-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.22 1.84 1.22 1.08 1.82 2.82 1.29 3.51.98.11-.76.42-1.29.77-1.59-2.67-.3-5.48-1.31-5.48-5.86 0-1.3.47-2.36 1.23-3.19-.12-.3-.53-1.52.12-3.18 0 0 1.01-.32 3.3 1.22a11.6 11.6 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.66.25 2.88.12 3.18.77.83 1.23 1.89 1.23 3.19 0 4.56-2.81 5.55-5.49 5.85.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z" />
            </svg>
          </a>
        </div>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const header = document.querySelector('[data-site-header]');
        if (!(header instanceof HTMLElement)) {
          return;
        }

        const compactAt = 96;
        const expandAt = 48;
        let ticking = false;
        let isCompact = false;

        const getScrollY = () => window.scrollY || document.documentElement.scrollTop || 0;

        const getNextState = () => {
          if (isCompact) {
            return getScrollY() > expandAt;
          }

          return getScrollY() > compactAt;
        };

        const syncHeaderState = () => {
          const nextState = getNextState();
          if (nextState === isCompact) {
            return;
          }

          isCompact = nextState;
          header.dataset.scrolled = String(nextState);
        };

        const requestSync = () => {
          if (ticking) {
            return;
          }

          ticking = true;
          window.requestAnimationFrame(() => {
            syncHeaderState();
            ticking = false;
          });
        };

        isCompact = getScrollY() > compactAt;
        header.dataset.scrolled = String(isCompact);
        syncHeaderState();
        window.addEventListener('scroll', requestSync, { passive: true });
        window.addEventListener('resize', requestSync);
      })();
    </script>
    <style>
      .site-highlight-gradient {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 0;
        height: 100vh;
        width: 100%;
        pointer-events: none;
        opacity: 0.25;
      }
    </style>
  </body>
</html>
